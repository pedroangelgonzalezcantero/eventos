Line       : 9
Statement  : -- =====================================================================
-- V5: Unificar alérgenos como fuente única de verdad en tabla guests
-- Migra allergen_entries existentes → guests (fuente canónica)
-- =====================================================================

-- Paso 1: Actualizar invitados existentes que tienen vacíos sus campos de
--         alergia pero sí tienen un registro en allergen_entries para el
--         mismo evento y nombre.
UPDATE guests g
SET
    allergies    = ae.allergies,
    diet         = ae.diet,
    observations = ae.observations
FROM allergen_entries ae
JOIN guest_tables gt ON g.table_id = gt.id AND gt.event_id = ae.event_id
WHERE g.guest_name = ae.guest_name
  AND (g.allergies    IS NULL OR g.allergies    = '')
  AND (g.diet         IS NULL OR g.diet         = '')
  AND (ae.allergies   IS NOT NULL AND ae.allergies   <> '')

